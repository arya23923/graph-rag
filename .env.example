# ── Neo4j Database ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Groq API (FREE — get key at https://console.groq.com) ────
# Powers: GraphRAG answer synthesis, LLM-assisted entity extraction
GROQ_API_KEY=your_openai_key_here

# ── OpenAI (optional fallback, paid) ─────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── App settings ──────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
MAX_FILE_SIZE=10485760
EXTRACTION_DOMAIN=tech

# ── LangChain (optional telemetry, disabled by default) ───────
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your_langsmith_key   # uncomment to enable LangSmith tracing
